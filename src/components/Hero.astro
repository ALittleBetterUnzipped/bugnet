---
// src/components/Hero.astro

const{
    headline = "From Larva to Launch"
} = Astro.props;

---

<section class="hero">
  <div class="container">
    <slot />
    <button class="button">See More</button>
    <button class="button">Talk To Us</button>
  </div>
</section>


<style>

/* ====== Import Fonts ===== */

@import url('https://fonts.googleapis.com/css2?family=Quicksand:wght@400;600;700&display=swap');

  /* ===== Hero Section ===== */
.hero {
    padding: 4rem 4rem 4rem;
    background: linear-gradient(135deg, #FE5F55 30%, #F2495C 50%, #E63462 80%
     100%);
    position: relative;
    overflow: hidden;
    min-height: 30vh;
    display: flex;
    align-items: center;
    font-family: 'Quicksand', sans-serif;  
    color: #FFFF;
    justify-content: center;
    text-align: left;       
}

  #banner {
    text-align: center;
    width: 100%;
  }

  #banner h1 {
    font-size: clamp(3rem, 6vw, 5rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    margin: 0;
  }

    .button{
        background-color: #333745;
        border: none;
        font-family: 'Quicksand', sans-serif; 
        color: #FFFFFF;
        padding: 0.5rem 1rem;
        border-radius: 32px;
        cursor: pointer;
    }

</style>