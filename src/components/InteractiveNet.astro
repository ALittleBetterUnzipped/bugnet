---
// src/components/InteractiveNet.astro
export interface Props {
  height?: number; // px height of the canvas area (ignored when overlay=true)
  nodeSpacing?: number; // roughly px^2 area per node (lower = denser)
  linkDistance?: number; // px, max distance to draw a line between two nodes
  mouseRadius?: number; // px, radius of cursor influence
  overlay?: boolean; // fill the parent (position: absolute; inset: 0) instead of taking its own height
  nodeColor?: string; // overrides --net-node-color
  lineColor?: string; // overrides --net-line-color
}

const {
  height = 320,
  nodeSpacing = 9000,
  linkDistance = 130,
  mouseRadius = 150,
  overlay = false,
  nodeColor,
  lineColor,
} = Astro.props;

const styleVars = [
  `--net-height:${height}px`,
  nodeColor ? `--net-node-color:${nodeColor}` : '',
  lineColor ? `--net-line-color:${lineColor}` : '',
]
  .filter(Boolean)
  .join(';');
---

<div
  class:list={['net-section', { overlay }]}
  style={styleVars}
  data-node-spacing={nodeSpacing}
  data-link-distance={linkDistance}
  data-mouse-radius={mouseRadius}
>
  <canvas class="net-canvas"></canvas>
</div>

<script>
  class Node {
    constructor(x, y) {
      this.x = x;
      this.y = y;
      const angle = Math.random() * Math.PI * 2;
      const speed = 0.15 + Math.random() * 0.25;
      this.vx = Math.cos(angle) * speed;
      this.vy = Math.sin(angle) * speed;
      this.baseRadius = 1.5 + Math.random() * 1.5;
    }

    step(width, height, pointer, mouseRadius) {
      // gentle drift
      this.x += this.vx;
      this.y += this.vy;

      // bounce off edges
      if (this.x < 0 || this.x > width) this.vx *= -1;
      if (this.y < 0 || this.y > height) this.vy *= -1;
      this.x = Math.max(0, Math.min(width, this.x));
      this.y = Math.max(0, Math.min(height, this.y));

      // gentle push away from pointer
      if (pointer.active) {
        const dx = this.x - pointer.x;
        const dy = this.y - pointer.y;
        const dist = Math.hypot(dx, dy);
        if (dist < mouseRadius && dist > 0.001) {
          const force = (1 - dist / mouseRadius) * 0.6;
          this.x += (dx / dist) * force;
          this.y += (dy / dist) * force;
        }
      }
    }
  }

  document.querySelectorAll('.net-section').forEach((section) => {
    const canvas = section.querySelector('canvas');
    const ctx = canvas.getContext('2d');
    const prefersReducedMotion = window.matchMedia(
      '(prefers-reduced-motion: reduce)'
    ).matches;

    const nodeSpacing = Number(section.dataset.nodeSpacing) || 9000;
    const linkDistance = Number(section.dataset.linkDistance) || 130;
    const mouseRadius = Number(section.dataset.mouseRadius) || 150;

    let cssWidth = 0;
    let cssHeight = 0;
    let nodes = [];
    let rafId = null;
    let running = false;

    const pointer = { x: 0, y: 0, active: false };

    function colors() {
      const styles = getComputedStyle(section);
      return {
        node: styles.getPropertyValue('--net-node-color').trim() || '#000000',
        line: styles.getPropertyValue('--net-line-color').trim() || '#000000',
      };
    }

    function makeNodes() {
      const area = cssWidth * cssHeight;
      const count = Math.max(12, Math.min(140, Math.round(area / nodeSpacing)));
      nodes = Array.from({ length: count }, () => {
        return new Node(Math.random() * cssWidth, Math.random() * cssHeight);
      });
    }

    function resize() {
      const rect = section.getBoundingClientRect();
      cssWidth = rect.width;
      cssHeight = rect.height;

      const dpr = window.devicePixelRatio || 1;
      canvas.width = Math.max(1, Math.round(cssWidth * dpr));
      canvas.height = Math.max(1, Math.round(cssHeight * dpr));
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);

      makeNodes();
    }

    function frame() {
      const { node: nodeColor, line: lineColor } = colors();

      ctx.clearRect(0, 0, cssWidth, cssHeight);

      // update
      nodes.forEach((n) => n.step(cssWidth, cssHeight, pointer, mouseRadius));

      // links between nearby nodes
      for (let i = 0; i < nodes.length; i++) {
        for (let j = i + 1; j < nodes.length; j++) {
          const a = nodes[i];
          const b = nodes[j];
          const dist = Math.hypot(a.x - b.x, a.y - b.y);
          if (dist < linkDistance) {
            ctx.globalAlpha = 1 - dist / linkDistance;
            ctx.strokeStyle = lineColor;
            ctx.lineWidth = 1;
            ctx.beginPath();
            ctx.moveTo(a.x, a.y);
            ctx.lineTo(b.x, b.y);
            ctx.stroke();
          }
        }
      }

      // links from pointer to nearby nodes
      if (pointer.active) {
        nodes.forEach((n) => {
          const dist = Math.hypot(n.x - pointer.x, n.y - pointer.y);
          if (dist < mouseRadius) {
            ctx.globalAlpha = 1 - dist / mouseRadius;
            ctx.strokeStyle = lineColor;
            ctx.lineWidth = 1;
            ctx.beginPath();
            ctx.moveTo(n.x, n.y);
            ctx.lineTo(pointer.x, pointer.y);
            ctx.stroke();
          }
        });
      }

      // nodes on top
      ctx.globalAlpha = 1;
      ctx.fillStyle = nodeColor;
      nodes.forEach((n) => {
        ctx.beginPath();
        ctx.arc(n.x, n.y, n.baseRadius, 0, Math.PI * 2);
        ctx.fill();
      });

      rafId = requestAnimationFrame(frame);
    }

    function start() {
      if (running || prefersReducedMotion) return;
      running = true;
      rafId = requestAnimationFrame(frame);
    }

    function stop() {
      running = false;
      if (rafId !== null) cancelAnimationFrame(rafId);
      rafId = null;
    }

    function toLocal(clientX, clientY) {
      const rect = canvas.getBoundingClientRect();
      return { x: clientX - rect.left, y: clientY - rect.top };
    }

    function onPointerMove(e) {
      const { x, y } = toLocal(e.clientX, e.clientY);
      pointer.x = x;
      pointer.y = y;
      pointer.active = true;
    }

    function onPointerLeave() {
      pointer.active = false;
    }

    function onTouchMove(e) {
      if (e.touches.length === 0) return;
      const touch = e.touches[0];
      const { x, y } = toLocal(touch.clientX, touch.clientY);
      pointer.x = x;
      pointer.y = y;
      pointer.active = true;
    }

    function onTouchEnd() {
      pointer.active = false;
    }

    resize();

    const resizeObserver = new ResizeObserver(() => resize());
    resizeObserver.observe(section);

    const intersectionObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => (entry.isIntersecting ? start() : stop()));
      },
      { threshold: 0 }
    );
    intersectionObserver.observe(canvas);

    canvas.addEventListener('pointermove', onPointerMove);
    canvas.addEventListener('pointerleave', onPointerLeave);
    canvas.addEventListener('touchmove', onTouchMove, { passive: true });
    canvas.addEventListener('touchend', onTouchEnd);

    if (!prefersReducedMotion) {
      frame();
      stop();
    } else {
      // draw one static frame for reduced-motion users
      frame();
      stop();
    }

    document.addEventListener(
      'astro:before-swap',
      () => {
        stop();
        resizeObserver.disconnect();
        intersectionObserver.disconnect();
        canvas.removeEventListener('pointermove', onPointerMove);
        canvas.removeEventListener('pointerleave', onPointerLeave);
        canvas.removeEventListener('touchmove', onTouchMove);
        canvas.removeEventListener('touchend', onTouchEnd);
      },
      { once: true }
    );
  });
</script>

<style>
  .net-section {
    width: 100%;
    height: var(--net-height, 320px);
    background: transparent !important;
    --net-node-color: rgba(0, 0, 0, 0.6);
    --net-line-color: rgba(0, 0, 0, 0.15);
  }

  .net-section.overlay {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
    pointer-events: auto;
  }

  @media (prefers-color-scheme: dark) {
    .net-section {
      --net-node-color: rgba(230, 230, 230, 0.7);
      --net-line-color: rgba(230, 230, 230, 0.15);
    }
  }

  .net-canvas {
    width: 100%;
    height: 100%;
    display: block;
    background: transparent !important;
    touch-action: none;
  }
</style>
